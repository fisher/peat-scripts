# peat-node runtime environment
# Edit this file for your node, then: systemctl restart peat-node
#
# All values below map directly to PEAT_NODE_* environment variables
# consumed by the peat-node binary.

# gRPC listen address (all interfaces, port 50081)
PEAT_NODE_LISTEN=0.0.0.0:50081

# Iroh QUIC UDP port (pinned to suppress external DNS/relay lookups)
PEAT_NODE_IROH_UDP_PORT=51081

# Formation identity — must match across all nodes in the mesh
PEAT_NODE_APP_ID=pi-demo

# Shared formation key — MUST be set before starting the service.
# Generate with: head -c 32 /dev/urandom | base64
# Must be identical on every node in the formation.
PEAT_NODE_SHARED_KEY="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="

# Persistent data directory
PEAT_NODE_DATA_DIR=/var/lib/peat-node

# Enable automatic sync with connected peers
PEAT_NODE_AUTO_SYNC=true

# Peer list — space-separated, format: <endpoint_id>@<ip>:<port>
# Leave empty on a fresh install; populate after retrieving endpoint IDs
# from peer nodes using: peat status --output json | jq -r .irohEndpointId
# Example:
# PEAT_NODE_PEERS=abc123@192.168.50.73:51081 def456@192.168.50.74:51081
PEAT_NODE_PEERS=

# Optional: path to creds.yaml (if used instead of individual env vars above)
# PEAT_CREDS=/etc/peat-node/creds.yaml

# Tweak GC to avoid OOM killer
PEAT_NODE_TOMBSTONE_TTL_HOURS=1
PEAT_NODE_GC_INTERVAL_SECS=300
PEAT_NODE_GC_BATCH_SIZE=100

# Recycle QUIC connections every 10 minutes (default may be longer)
PEAT_CONNECTION_RECYCLE_SECS=600

# ---
# Enable compaction — critical for long-running telemetry pushers on RPi
PEAT_COMPACTION_ENABLED=true

# Explicitly name your collection rather than relying on auto-detection
PEAT_COMPACTION_COLLECTIONS=telemetry

# Aggressive settings for memory-constrained RPi
# Run compaction every 60 seconds
PEAT_COMPACTION_INTERVAL_SECS=60
# Trigger when collection history exceeds 16 KB
PEAT_COMPACTION_THRESHOLD_BYTES=16384

# --- Uncomment to tune advanced options ---
# PEAT_NODE_ENCRYPTION_KEY=
# PEAT_NODE_BLOB_STALL_TIMEOUT_SECS=
# PEAT_NODE_AGENT_ADDR=
# PEAT_NODE_ATTACHMENT_ROOT=
# PEAT_NODE_ATTACHMENT_MAX_FILE_BYTES=
